# ─────────────────────────────────────────────────────────────────────────────
# Bluetick — Server Environment Variables Template
# Copy this file to .env and fill in all values before starting the server.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Frontend URL (CORS whitelist) ───────────────────────────────────────────
# Your production domain. No trailing slash.
FRONTEND_URL=https://yourdomain.com

# ─── PostgreSQL Database ─────────────────────────────────────────────────────
DB_NAME=whatsapp_saas
DB_USER=bluetick_user
DB_PASS=YourStrongPasswordHere
DB_HOST=localhost
DB_PORT=5432

# ─── JWT Auth Secret ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# ─── Webhook Security Token ──────────────────────────────────────────────────
# This MUST match the "Verify Token" entered in your Meta Developer Dashboard.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_VERIFY_TOKEN=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ─── Meta / Facebook App ─────────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Your App → Settings → Basic
FB_CLIENT_ID=your_facebook_app_id
FB_CLIENT_SECRET=your_facebook_app_secret

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
